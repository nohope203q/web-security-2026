<?xml version="1.0" encoding="UTF-8"?>
<persistence version="3.0" xmlns="https://jakarta.ee/xml/ns/persistence" 
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd">
    
    <persistence-unit name="pcshopPU" transaction-type="RESOURCE_LOCAL">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>
        
        <class>model.Review</class>
        <class>model.Address</class>
        <class>model.ChatConversation</class>
        <class>model.Order</class>
        <class>model.User</class>
        <class>model.Coupon</class>
        <class>model.Invoice</class>
        <class>model.Payment</class>
        <class>model.Product</class>
        <class>model.OrderItem</class>
        <class>model.Cart</class>
        <class>model.ChatMessage</class>
        <class>model.LineItem</class>
        <class>model.Announcement</class>
        <class>model.Category</class>

        <properties>
            <property name="jakarta.persistence.jdbc.driver" value="com.mysql.cj.jdbc.Driver"/>
            <property name="jakarta.persistence.jdbc.url" value="jdbc:mysql://127.0.0.1:3306/web-database?serverTimezone=UTC&amp;useSSL=false&amp;allowPublicKeyRetrieval=true"/>
            <property name="jakarta.persistence.jdbc.user" value="root"/>
            <property name="jakarta.persistence.jdbc.password" value="123456a@"/>

            <property name="hibernate.dialect" value="org.hibernate.dialect.MariaDBDialect"/>
            
            <property name="hibernate.temp.use_jdbc_metadata_defaults" value="false"/>

            <property name="hibernate.hbm2ddl.auto" value="update"/>
            <property name="hibernate.show_sql" value="true"/>
            <property name="hibernate.format_sql" value="true"/>
            
            <property name="hibernate.connection.charSet" value="UTF-8"/>
        </properties>
    </persistence-unit>
</persistence>